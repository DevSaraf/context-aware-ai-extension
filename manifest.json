{
  "manifest_version": 3,
  "name": "AI Context Assistant",
  "version": "1.0.0",
  "description": "Company context assistant for AI chat platforms",

  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://krabai.azurewebsites.net/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Context Assistant"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
